{
  "expo": {
    "name": "Proteinska Dijeta",
    "slug": "proteinska-dijeta",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "proteinskadijeta",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-flame.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0C11"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.maradil.proteinskadijeta",
      "adaptiveIcon": {
        "backgroundColor": "#0B0C11",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "411a5d92-596c-45aa-9a6e-82ccc1682d84"
      }
    },
    "owner": "maradil"
  }
}
